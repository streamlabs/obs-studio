@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

list(APPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}/finders")

set(_OBS_PREV_CMAKE_PREFIX_PATH "${CMAKE_PREFIX_PATH}")
list(PREPEND CMAKE_PREFIX_PATH "${PACKAGE_PREFIX_DIR}" "${CMAKE_CURRENT_LIST_DIR}")

set(_OBS_BUNDLED_DEPENDENCY_PREFIXES "@OBS_BUNDLED_DEPENDENCY_PREFIXES@")
foreach(_OBS_DEPENDENCY_PREFIX IN LISTS _OBS_BUNDLED_DEPENDENCY_PREFIXES)
  if(EXISTS "${_OBS_DEPENDENCY_PREFIX}")
    list(PREPEND CMAKE_PREFIX_PATH "${_OBS_DEPENDENCY_PREFIX}")
  endif()
endforeach()

if(MSVC)
  find_dependency(w32-pthreads REQUIRED)
endif()
find_dependency(SIMDe REQUIRED)
find_dependency(Threads REQUIRED)

set(CMAKE_PREFIX_PATH "${_OBS_PREV_CMAKE_PREFIX_PATH}")
unset(_OBS_PREV_CMAKE_PREFIX_PATH)
unset(_OBS_BUNDLED_DEPENDENCY_PREFIXES)
unset(_OBS_DEPENDENCY_PREFIX)

include("${CMAKE_CURRENT_LIST_DIR}/@TARGETS_EXPORT_NAME@.cmake")
check_required_components("@PROJECT_NAME@")

set_property(TARGET OBS::libobs APPEND PROPERTY INTERFACE_COMPILE_DEFINITIONS HAVE_OBSCONFIG_H)
